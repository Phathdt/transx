# Domain APIs (wallet/transfer/inbox) via Traefik — Bearer AT from memory.
# Browser-facing; baked into the client bundle at build time (Docker ARG).
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Server-side RR BFF → Go auth (defaults to VITE_API_BASE_URL if unset).
# Local pnpm: http://localhost:4000/api/v1
# Docker compose: http://traefik/api/v1
# AUTH_API_BASE_URL=http://localhost:4000/api/v1

# Set true behind HTTPS so refresh cookie includes Secure.
# COOKIE_SECURE=false

# Dedicated RR Redis for SSR AT cache (rr:at:*). Not Go auth Redis.
# Local pnpm: redis://localhost:16380 (compose publishes redis-rr host port).
# Docker compose service: redis://redis-rr:6379
RR_REDIS_URL=redis://localhost:16380
# Cache TTL ≈ auth.jwt_ttl (default 15m).
# RR_AT_TTL_SECONDS=900
